{
  "name": "091-mouse-coordinates",
  "title": "Verify mouseClick with absolute coordinates",
  "engine": "playwright",
  "actions": [
    { "action": "goto", "params": { "url": "/" } },
    { "action": "mouseClick", "params": { "x": 50, "y": 50 } },
    {
      "action": "extract",
      "params": {
        "coords": { "selector": "#coords" }
      }
    }
  ],
  "expected": {
    "data": {
      "coords": "X: 50, Y: 50"
    }
  }
}
