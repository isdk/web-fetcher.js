{
  "name": "104-mouse-wheel-ensure-visible",
  "title": "Verify mouseWheel with selector automatically ensures visibility",
  "engine": "playwright",
  "actions": [
    { "action": "goto", "params": { "url": "/" } },
    { "action": "mouseWheel", "params": { "selector": "#scroll-area", "deltaY": 50 } },
    {
      "action": "extract",
      "params": {
        "status": { "selector": "#status" }
      }
    }
  ],
  "expected": {
    "data": {
      "status": "Wheeled DeltaY: 50"
    }
  }
}
