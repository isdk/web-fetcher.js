{
  "title": "should support enhanced mouse trajectories with steps and selectors",
  "timeout": 30000,
  "engine": "browser",
  "options": {
    "debug": true
  },
  "actions": [
    {
      "action": "goto",
      "params": { "url": "/" }
    },
    {
      "action": "mouseMove",
      "params": {
        "selector": "#target",
        "steps": 2
      }
    },
    {
      "action": "evaluate",
      "storeAs": "moveResult",
      "params": {
        "fn": "() => ({ pathLength: window.mousePath.length, hovered: window.hovered })"
      }
    },
    {
      "action": "evaluate",
      "params": {
        "fn": "() => { window.mousePath = []; window.hovered = false; }"
      }
    },
    {
      "action": "mouseClick",
      "params": {
        "x": 100,
        "y": 100,
        "steps": 1
      }
    },
    {
      "action": "evaluate",
      "storeAs": "clickResult",
      "params": {
        "fn": "() => ({ pathLength: window.mousePath.length, lastClick: window.lastClick })"
      }
    },
    {
      "action": "evaluate",
      "params": {
        "fn": "() => { window.mousePath = []; window.lastClick = null; }"
      }
    },
    {
      "action": "mouseClick",
      "params": {
        "selector": "#target",
        "steps": 2
      }
    },
    {
      "action": "evaluate",
      "storeAs": "selectorClickResult",
      "params": {
        "fn": "() => ({ pathLength: window.mousePath.length, lastClick: window.lastClick })"
      }
    }
  ],
  "expected": {
    "outputs": {
      "moveResult": {
        "hovered": true
      },
      "clickResult": {
        "lastClick": { "x": 100, "y": 100 }
      },
      "selectorClickResult": {
        "lastClick": { "x": 350, "y": 250 }
      }
    }
  }
}
